# Railway -> Variables tab. railway_entrypoint.py reads these at boot
# and generates config.toml. Never commit real keys.

# --- LLM (script generation) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash
# Fallback when Gemini rate-limits:
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-chat

# --- Stock footage ---
VIDEO_SOURCE=pexels
# Comma-separate multiple keys to spread rate limits: key1,key2
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- Subtitles (faster-whisper, CPU) ---
SUBTITLE_PROVIDER=whisper
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=CPU
WHISPER_COMPUTE_TYPE=int8

# --- Cloudflare R2 (optional, for offloading rendered videos) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=videos
